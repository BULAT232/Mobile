<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="CheckersGame.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:CheckersGame.Views"
    Shell.FlyoutBehavior="Flyout"
    Title="Шашки">

    <FlyoutItem Title="Главная" Icon="{x:Null}">
        <ShellContent
            Title="Главная"
            ContentTemplate="{DataTemplate views:MainMenuPage}"
            Route="MainMenuPage" />
    </FlyoutItem>

    <FlyoutItem Title="Профили" Icon="{x:Null}">
        <ShellContent
            Title="Профили"
            ContentTemplate="{DataTemplate views:ProfilesPage}"
            Route="ProfilesPage" />
    </FlyoutItem>

    <FlyoutItem Title="Статистика" Icon="{x:Null}">
        <ShellContent
            Title="Статистика"
            ContentTemplate="{DataTemplate views:StatisticsPage}"
            Route="StatisticsPage" />
    </FlyoutItem>

    <FlyoutItem Title="История игр" Icon="{x:Null}">
        <ShellContent
            Title="История игр"
            ContentTemplate="{DataTemplate views:GameHistoryPage}"
            Route="GameHistoryPage" />
    </FlyoutItem>

    <FlyoutItem Title="Настройки" Icon="{x:Null}">
        <ShellContent
            Title="Настройки"
            ContentTemplate="{DataTemplate views:SettingsPage}"
            Route="SettingsPage" />
    </FlyoutItem>

</Shell>
