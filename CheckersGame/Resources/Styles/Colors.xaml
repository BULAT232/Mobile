<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Color x:Key="Primary">#512BD4</Color>
    <Color x:Key="PrimaryDark">#ac99ea</Color>
    <Color x:Key="PrimaryDarkText">#242424</Color>
    <Color x:Key="Secondary">#DFD8F7</Color>
    <Color x:Key="SecondaryDarkText">#9880e5</Color>
    <Color x:Key="Tertiary">#2B0B98</Color>
    <Color x:Key="White">#FFFFFF</Color>
    <Color x:Key="Black">#000000</Color>
    <Color x:Key="Magenta">#D600AA</Color>
    <Color x:Key="MidnightBlue">#190649</Color>
    <Color x:Key="OffBlack">#1f1f1f</Color>

    <Color x:Key="Gray100">#E1E1E1</Color>
    <Color x:Key="Gray200">#C8C8C8</Color>
    <Color x:Key="Gray300">#ACACAC</Color>
    <Color x:Key="Gray400">#919191</Color>
    <Color x:Key="Gray500">#6E6E6E</Color>
    <Color x:Key="Gray600">#404040</Color>
    <Color x:Key="Gray900">#212121</Color>
    <Color x:Key="Gray950">#141414</Color>

    <!-- Board theme colors -->
    <Color x:Key="ClassicLight">#EBECD0</Color>
    <Color x:Key="ClassicDark">#739552</Color>
    <Color x:Key="WoodLight">#F0D9B5</Color>
    <Color x:Key="WoodDark">#B58863</Color>
    <Color x:Key="DarkModeLight">#4B4B4B</Color>
    <Color x:Key="DarkModeDark">#2C2C2C</Color>

    <!-- Game colors -->
    <Color x:Key="SelectedCell">#FFEB3B</Color>
    <Color x:Key="ValidMoveCell">#81C784</Color>
    <Color x:Key="CaptureCell">#EF5350</Color>
    <Color x:Key="LastMoveCell">#64B5F6</Color>

    <Color x:Key="WhitePiece">#FAFAFA</Color>
    <Color x:Key="BlackPiece">#212121</Color>

</ResourceDictionary>
