<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:CheckersGame.ViewModels"
             x:Class="CheckersGame.Views.MainMenuPage"
             x:DataType="vm:MainMenuViewModel"
             Title="Шашки">

    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="30">

            <!-- Заголовок -->
            <Label Text="♟ Шашки"
                   FontSize="36"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   TextColor="{StaticResource Primary}"
                   Margin="0,20,0,0" />

            <Label Text="Checkers Game"
                   FontSize="16"
                   HorizontalOptions="Center"
                   TextColor="{StaticResource Gray400}" />

            <!-- Статистика -->
            <Frame Padding="15" Margin="0,10,0,0">
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="30">
                    <VerticalStackLayout HorizontalOptions="Center">
                        <Label Text="{Binding TotalGames}"
                               FontSize="24"
                               FontAttributes="Bold"
                               HorizontalOptions="Center" />
                        <Label Text="Игр сыграно"
                               FontSize="12"
                               TextColor="{StaticResource Gray400}"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>
                    <VerticalStackLayout HorizontalOptions="Center">
                        <Label Text="{Binding TotalProfiles}"
                               FontSize="24"
                               FontAttributes="Bold"
                               HorizontalOptions="Center" />
                        <Label Text="Игроков"
                               FontSize="12"
                               TextColor="{StaticResource Gray400}"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </HorizontalStackLayout>
            </Frame>

            <!-- Кнопки меню -->
            <Button Text="🎮  Новая игра"
                    Command="{Binding NavigateToNewGameCommand}"
                    FontSize="18"
                    HeightRequest="55"
                    Margin="0,10,0,0" />

            <Button Text="👤  Профили игроков"
                    Command="{Binding NavigateToProfilesCommand}"
                    FontSize="16"
                    HeightRequest="50"
                    BackgroundColor="{StaticResource Secondary}"
                    TextColor="{StaticResource PrimaryDarkText}" />

            <Button Text="📊  Статистика"
                    Command="{Binding NavigateToStatisticsCommand}"
                    FontSize="16"
                    HeightRequest="50"
                    BackgroundColor="{StaticResource Secondary}"
                    TextColor="{StaticResource PrimaryDarkText}" />

            <Button Text="📋  История игр"
                    Command="{Binding NavigateToHistoryCommand}"
                    FontSize="16"
                    HeightRequest="50"
                    BackgroundColor="{StaticResource Secondary}"
                    TextColor="{StaticResource PrimaryDarkText}" />

            <Button Text="⚙️  Настройки"
                    Command="{Binding NavigateToSettingsCommand}"
                    FontSize="16"
                    HeightRequest="50"
                    BackgroundColor="{StaticResource Secondary}"
                    TextColor="{StaticResource PrimaryDarkText}" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
