<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:CheckersGame.ViewModels"
             xmlns:models="clr-namespace:CheckersGame.Models"
             x:Class="CheckersGame.Views.GameHistoryPage"
             x:DataType="vm:GameHistoryViewModel"
             Title="История игр">

    <Grid RowDefinitions="*,Auto" Padding="15">

        <!-- Список игр -->
        <CollectionView ItemsSource="{Binding GameRecords}"
                        IsVisible="{Binding IsEmpty, Converter={StaticResource InvertBoolConverter}}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:GameRecord">
                    <Frame Padding="12" Margin="0,4" HasShadow="False">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:GameHistoryViewModel}}, Path=ShowGameDetailsCommand}"
                                CommandParameter="{Binding .}" />
                        </Frame.GestureRecognizers>

                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" RowSpacing="3">
                            <!-- Игроки -->
                            <Label FontSize="14" FontAttributes="Bold">
                                <Label.Text>
                                    <MultiBinding StringFormat="{}{0} vs {1}">
                                        <Binding Path="Player1Name" />
                                        <Binding Path="Player2Name" />
                                    </MultiBinding>
                                </Label.Text>
                            </Label>

                            <!-- Дата -->
                            <Label Grid.Column="1"
                                   Text="{Binding Date, StringFormat='{0:dd.MM.yy}'}"
                                   FontSize="12"
                                   TextColor="{StaticResource Gray400}"
                                   VerticalOptions="Center" />

                            <!-- Тип игры и результат -->
                            <HorizontalStackLayout Grid.Row="1" Spacing="10">
                                <Label Text="{Binding GameTypeDisplay}"
                                       FontSize="12"
                                       TextColor="{StaticResource Gray400}" />
                                <Label Text="|"
                                       FontSize="12"
                                       TextColor="{StaticResource Gray300}" />
                                <Label Text="{Binding ResultDisplay}"
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource Primary}" />
                            </HorizontalStackLayout>

                            <!-- Детали -->
                            <HorizontalStackLayout Grid.Row="2" Spacing="15">
                                <Label Text="{Binding MoveCount, StringFormat='Ходов: {0}'}"
                                       FontSize="11"
                                       TextColor="{StaticResource Gray400}" />
                                <Label Text="{Binding DurationDisplay, StringFormat='Время: {0}'}"
                                       FontSize="11"
                                       TextColor="{StaticResource Gray400}" />
                            </HorizontalStackLayout>
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Пустое состояние -->
        <VerticalStackLayout IsVisible="{Binding IsEmpty}"
                             VerticalOptions="Center"
                             HorizontalOptions="Center"
                             Spacing="10">
            <Label Text="📋"
                   FontSize="60"
                   HorizontalOptions="Center" />
            <Label Text="Нет записей"
                   FontSize="18"
                   HorizontalOptions="Center"
                   TextColor="{StaticResource Gray400}" />
            <Label Text="Сыграйте первую игру!"
                   FontSize="14"
                   HorizontalOptions="Center"
                   TextColor="{StaticResource Gray400}" />
        </VerticalStackLayout>

        <!-- Кнопка очистки -->
        <Button Grid.Row="1"
                Text="🗑  Очистить историю"
                Command="{Binding ClearHistoryCommand}"
                FontSize="14"
                HeightRequest="44"
                BackgroundColor="#F44336"
                IsVisible="{Binding IsEmpty, Converter={StaticResource InvertBoolConverter}}"
                Margin="0,10,0,0" />

    </Grid>

</ContentPage>
