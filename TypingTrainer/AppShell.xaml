<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="TypingTrainer.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:TypingTrainer.Views"
    Shell.FlyoutBehavior="Flyout"
    Title="Typing Trainer">

    <FlyoutItem Title="Главная" Icon="{x:Null}">
        <ShellContent
            Title="Главная"
            ContentTemplate="{DataTemplate views:MainPage}"
            Route="MainPage" />
    </FlyoutItem>

    <FlyoutItem Title="Словари" Icon="{x:Null}">
        <ShellContent
            Title="Словари"
            ContentTemplate="{DataTemplate views:DictionaryListPage}"
            Route="DictionaryListPage" />
    </FlyoutItem>

    <FlyoutItem Title="Статистика" Icon="{x:Null}">
        <ShellContent
            Title="Статистика"
            ContentTemplate="{DataTemplate views:StatisticsPage}"
            Route="StatisticsPage" />
    </FlyoutItem>

    <FlyoutItem Title="Настройки" Icon="{x:Null}">
        <ShellContent
            Title="Настройки"
            ContentTemplate="{DataTemplate views:SettingsPage}"
            Route="SettingsPage" />
    </FlyoutItem>

</Shell>
